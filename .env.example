# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# Summary style: short, detailed, reel
GEMINI_SUMMARY_STYLE=detailed
GEMINI_MAX_RETRIES=3
GEMINI_BASE_DELAY=1.0

# ── App ───────────────────────────────────────────────────────
DEBUG=false

# ── CORS (comma-separated origins, "*" for dev) ──────────────
CORS_ORIGINS=*

# ── Scheduler ─────────────────────────────────────────────────
# Hour and minute (UTC) when the daily job runs
SCHEDULER_HOUR_UTC=0
SCHEDULER_MINUTE_UTC=0
# Set to false to disable the scheduler (useful for dev/test)
SCHEDULER_ENABLED=true
